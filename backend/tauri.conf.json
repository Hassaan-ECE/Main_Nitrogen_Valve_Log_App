{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Valve Log",
  "version": "0.1.3",
  "identifier": "valve-log",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Valve Log",
        "width": 360,
        "height": 440,
        "minWidth": 360,
        "minHeight": 440,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://github.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Syed Hassaan Shah",
    "copyright": "Copyright (c) 2026 Syed Hassaan Shah",
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4QkIwNjkzMUE5REE1RTQKUldUa3BaMGFrd2E3dUdJdU9ZaS9OalVadUtTTW5LcGd2U0wzSDdubUNCMHRDRjUveDRzWWl5TVAK",
      "endpoints": [
        "https://github.com/Hassaan-ECE/Main_Nitrogen_Valve_Log_App/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
